{
  "name": "juice-shop-tests-opus",
  "version": "1.0.0",
  "description": "Playwright test framework for OWASP Juice Shop",
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "test:ui:sanity": "npx playwright test --project=ui-sanity",
    "test:ui:regression": "npx playwright test --project=ui-regression",
    "test:api:sanity": "npx playwright test --project=api-sanity",
    "test:api:regression": "npx playwright test --project=api-regression",
    "test:headed":       "playwright test --headed",
    "allure:serve":      "allure serve allure-results",
    "allure:generate":   "allure generate allure-results --clean -o allure-report",
    "allure:open":       "allure open allure-report",
    "report":            "npm run allure:generate && npm run allure:open",

    "clean":             "rm -rf allure-results allure-report playwright-report test-results",
    "clean:all":         "npm run clean && rm -rf node_modules && npm install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "allure-commandline": "^2.38.0",
    "allure-playwright": "^3.6.0"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.3.1"
  }
}
