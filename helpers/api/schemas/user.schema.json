{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["status", "data"],
  "properties": {
    "status": { "type": "string", "const": "success" },
    "data": {
      "type": "object",
      "required": ["id", "email"],
      "properties": {
        "id":       { "type": "integer" },
        "email":    { "type": "string", "format": "email" },
        "role":     { "type": "string" }
      }
    }
  }
}
